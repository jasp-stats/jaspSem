msgctxt "MediationAnalysis|"
msgid ""
"One or multiple predictor variables predicting the mediators and the outcome "
"variables."
msgstr ""
"Una o varias variables predictoras que predicen los mediadores y las "
"variables de resultados."

msgctxt "MediationAnalysis|"
msgid ""
"Variables through which the indirect effect of the predictors on the "
"outcomes is hypothesized to flow."
msgstr ""
"Variables a través de las que se hipotetiza que fluye el efecto indirecto de "
"los predictores sobre los resultados."

msgctxt "MediationAnalysis|"
msgid "Variables predicted by the predictors and the mediators."
msgstr "Variables predichas por los predictores y los mediadores."

msgctxt "MediationAnalysis|"
msgid ""
"Variables explaining the predictors, mediators, and outcomes. Direct, "
"indirect, and total effects are estimated conditional on these variables."
msgstr ""
"Variables que explican los predictores, los mediadores y los resultados. Se "
"estiman los efectos directos, indirectos y totales condicionados sobre estas "
"variables."

msgctxt "MediationAnalysis|"
msgid ""
"Options for standardization, additional parameter estimates, and model "
"display."
msgstr ""
"Opciones para la tipificación, la estimación adicional de parámetros y la "
"presentación del modelo."

msgctxt "MediationAnalysis|"
msgid "Standardize all variables (mean = 0, sd = 1) before estimation."
msgstr ""
"Tipificar todas las variables (Media = 0, DT = 1) antes de la estimación."

msgctxt "MediationAnalysis|"
msgid "Type of standardization."
msgstr "Tipo de tipificación."

msgctxt "MediationAnalysis|"
msgid "Standardize based on variances of both observed and latent variables."
msgstr ""
"Tipificar en base a las varianzas de las variables tanto observadas como "
"latentes."

msgctxt "MediationAnalysis|"
msgid "Standardize based on latent variable variances only."
msgstr ""
"Tipificar en base únicamente a las varianzas de las variables latentes."

msgctxt "MediationAnalysis|"
msgid "Standardize excluding exogenous covariates."
msgstr "Tipificar excluyendo covariables exógenas."

msgctxt "MediationAnalysis|"
msgid "Display the lavaan syntax used to estimate the model."
msgstr "Presentar la sintaxis lavaan utilizada para estimar el modelo."

msgctxt "MediationAnalysis|"
msgid ""
"Display the proportion of variance explained for each endogenous variable."
msgstr ""
"Presentar la proporción de varianza explicada para cada variable endógena."

msgctxt "MediationAnalysis|"
msgid "Additional parameter estimate tables to display."
msgstr "Tablas de estimaciones adicionales de parámetros para presentar."

msgctxt "MediationAnalysis|"
msgid "Display total indirect effects summed across all mediators."
msgstr ""
"Presentar efectos indirectos totales sumados entre todos los mediadores."

msgctxt "MediationAnalysis|"
msgid "Display residual covariances between variables."
msgstr "Presentar covarianzas de errores entre variables."

msgctxt "MediationAnalysis|"
msgid "Display the path coefficients of the model."
msgstr "Presentar los coeficientes de las rutas del modelo."

msgctxt "MediationAnalysis|"
msgid "Options for generating plots of the mediation model."
msgstr "Opciones para generar gráficos del modelo de mediación."

msgctxt "MediationAnalysis|"
msgid "Display a path diagram of the mediation model."
msgstr "Presentar un diagrama de rutas del modelo de mediación."

msgctxt "MediationAnalysis|"
msgid "Display parameter estimates on the path diagram."
msgstr "Presentar estimaciones de parámetros en el diagrama de rutas."

msgctxt "MediationAnalysis|"
msgid "Display a legend in the path diagram."
msgstr "Presentar una leyenda en el diagrama de rutas."

msgctxt "Mimic|"
msgid ""
"Observed indicator variables that define the latent variable in the MIMIC "
"model."
msgstr ""
"Variables indicadoras observadas que definen la variable latente en el "
"modelo MIMIC."

msgctxt "Mimic|"
msgid ""
"Observed predictor variables (causes) that directly influence the latent "
"variable."
msgstr ""
"Variables predictoras observadas (causas) que influyen directamente en la "
"variable latente."

msgctxt "Mimic|"
msgid ""
"Options for standardization, model syntax display, and additional output."
msgstr ""
"Opciones para tipificación, presentación de la sintaxis del modelo y salida "
"adicional de resultados."

msgctxt "Mimic|"
msgid "Standardize all variables (mean = 0, sd = 1) before estimation."
msgstr ""
"Tipificar todas las variables (Media = 0, DT = 1) antes de la estimación."

msgctxt "Mimic|"
msgid "Type of standardization."
msgstr "Tipo de tipificación."

msgctxt "Mimic|"
msgid "Standardize based on variances of both observed and latent variables."
msgstr ""
"Tipificar en base a las varianzas de las variables tanto observadas como "
"latentes."

msgctxt "Mimic|"
msgid "Standardize based on latent variable variances only."
msgstr ""
"Tipificar en base únicamente a las varianzas de las variables latentes."

msgctxt "Mimic|"
msgid "Standardize excluding exogenous covariates."
msgstr "Tipificar excluyendo covariables exógenas."

msgctxt "Mimic|"
msgid "Display the lavaan syntax used to estimate the model."
msgstr "Presentar la sintaxis lavaan utilizada para estimar el modelo."

msgctxt "Mimic|"
msgid ""
"Display the proportion of variance explained for each endogenous variable."
msgstr ""
"Presentar la proporción de varianza explicada para cada variable endógena."

msgctxt "Mimic|"
msgid ""
"Display additional fit indices for evaluating model fit (e.g., CFI, TLI, "
"RMSEA, SRMR)."
msgstr ""
"Presentar índices adicionales de ajuste para evaluar el ajuste del modelo (p."
"e. IAC, ILT, REACM, RECMS)."

msgctxt "Mimic|"
msgid "Options for generating plots of the MIMIC model."
msgstr "Opciones para generar gráficos del modelo MIMIC."

msgctxt "Mimic|"
msgid "Display a path diagram of the MIMIC model."
msgstr "Presentar un diagrama de rutas del modelo MIMIC."

msgctxt "Mimic|"
msgid "Display parameter estimates on the path diagram."
msgstr "Presentar estimaciones de parámetros en el diagrama de rutas."

msgctxt "Mimic|"
msgid "Display a legend in the path diagram."
msgstr "Presentar una leyenda en el diagrama de rutas."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Define latent factors and assign observed indicator variables to each factor."
msgstr ""
"Definir factores latentes y asignar variables observadas indicadoras a cada "
"factor."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Specify moderator variables and their effects on measurement model "
"parameters."
msgstr ""
"Especificar variables moderadoras y sus efectos sobre los parámetros del "
"modelo de medición."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Variables hypothesized to moderate the measurement model parameters. "
"Continuous moderators can optionally include squared and cubic effects."
msgstr ""
"Variables que se supone que moderan los parámetros del modelo de medición. "
"Los moderadores continuos pueden incluir efectos cuadrados y cúbicos, "
"opcionalmente."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid "Include a quadratic (squared) effect for this moderator."
msgstr "Incluir un efecto cuadrado para este moderador."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid "Include a cubic effect for this moderator."
msgstr "Incluir un efecto cúbico para este moderador."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Click to start or synchronize the analysis. The analysis does not run "
"automatically due to computational intensity."
msgstr ""
"Hacer clic para iniciar o sincronizar el análisis. El análisis no se ejecuta "
"automáticamente debido a la intensidad del cálculo."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Check measurement invariance assumptions by testing model fit across groups "
"defined by the moderator variables."
msgstr ""
"Comprobar los supuestos de invariancia de la medición contrastando el ajuste "
"del modelo entre los grupos definidos por las variables moderadoras."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Fit the measurement model separately in each group to verify that the model "
"fits adequately before testing moderation."
msgstr ""
"Ajustar el modelo de medición por separado en cada grupo para verificar que "
"el modelo se ajusta adecuadamente antes de contrastar la moderación."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Number of groups into which continuous moderator variables are split for the "
"assumption check."
msgstr ""
"Número de grupos en los que se dividen las variables continuas moderadoras "
"para comprobar los supuestos."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Save the group variable created by splitting the continuous moderator to the "
"dataset."
msgstr ""
"Guardar la variable de grupos creada dividiendo el moderador continuo, en el "
"conjunto de datos."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid "Include interaction terms between pairs of moderators."
msgstr "Incluir términos de interacciones entre pares de moderadores."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Configure invariance test levels and specify which individual parameters "
"should be tested for moderation."
msgstr ""
"Configurar los niveles de los contrastes de invariancia y especificar qué "
"parámetros individuales deben contrastarse para la moderación."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Select the levels of measurement invariance to test. Each level constrains "
"an additional set of parameters to be equal across moderator values."
msgstr ""
"Seleccionar los niveles de invariancia de la medición a contrastar. Cada "
"nivel restringe un conjunto adicional de parámetros a que sean iguales entre "
"los valores de los moderadores."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Test configural invariance: same factor structure across groups but all "
"parameters free."
msgstr ""
"Contrastar la invariancia configurativa: la misma estructura de factores "
"entre grupos, pero todos los parámetros libres."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Test metric invariance: constrain factor loadings to be equal across groups."
msgstr ""
"Contrastar la invariancia métrica: restringir las cargas de los factores a "
"que sean iguales entre grupos."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Test scalar invariance: constrain factor loadings and intercepts to be equal "
"across groups."
msgstr ""
"Contrastar la invariancia escalar: restringir las cargas de los factores y "
"las constantes a que sean iguales entre grupos."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"Test strict invariance: constrain factor loadings, intercepts, and residual "
"variances to be equal across groups."
msgstr ""
"Contrastar la invariancia estricta: restringir las cargas de los factores, "
"las constantes y las varianzas de los errores a que sean iguales entre "
"grupos."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid "Define a custom set of parameter constraints for invariance testing."
msgstr ""
"Definir un conjunto personalizado de restricciones de parámetros para "
"contrastar la invariancia."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid ""
"For each invariance level, specify which individual measurement parameters "
"should be tested for moderation effects."
msgstr ""
"Para cada nivel de invariancia, especificar qué parámetros individuales de "
"medición deben contrastarse para los efectos de moderación."

msgctxt "ModeratedNonLinearFactorAnalysis|"
msgid "Estimation Options"
msgstr "Opciones de la estimación"

